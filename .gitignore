# Release-workflow engine checkout — .github/workflows/release.yml
# clones lexfrei/pogo-pvp-engine into .engine-src/ and wires it
# through BuildKit's `build-contexts: engine=./.engine-src`, so the
# Containerfile can resolve the go.mod replace directive in CI.
# Local docker builds use ENGINE_PATH (default ../pogo-pvp-engine)
# and do not touch .engine-src/.
/.engine-src/
